---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'profile';
  jsonLd?: object;
}

const { 
  title, 
  description, 
  image = '/og-image.jpg', 
  canonicalURL = Astro.url.href,
  type = 'website',
  jsonLd
} = Astro.props;

const siteName = "Juan Jose Gonzales Centurión";
const fullTitle = `${title} | ${siteName}`;

// Default Person Schema
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Juan Jose Gonzales Centurión",
  "jobTitle": "Digital Marketing & Web Specialist",
  "url": "https://juanjosegonzales.vercel.app",
  "sameAs": [
    "https://linkedin.com/in/juangonzalescenturion",
    "https://behance.net/juangonzalesc"
  ]
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Robots -->
<meta name="robots" content="index, follow" />

<!-- Structured Data -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
{jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
