    <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500">
      <p>&copy; {year} Juan Jose Gonzales Centurión. Todos los derechos reservados.</p>
      <div class="mt-4 md:mt-0 flex space-x-6">
        <a href="/cv-juan-jose-gonzales.pdf" download class="inline-flex items-center text-blue-600 font-semibold hover:underline">
