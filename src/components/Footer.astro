---
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <h3 class="text-lg font-bold mb-4">Juan Jose Gonzales</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Especialista en Marketing Digital y Desarrollo Web enfocado en resultados medibles y optimización técnica.
        </p>
      </div>
      
      <div>
        <h3 class="text-lg font-bold mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="/sobre-mi" class="hover:text-blue-600 transition-colors">Sobre Mí</a></li>
          <li><a href="/portfolio" class="hover:text-blue-600 transition-colors">Proyectos</a></li>
          <li><a href="/habilidades-servicios" class="hover:text-blue-600 transition-colors">Habilidades</a></li>
          <li><a href="/contacto" class="hover:text-blue-600 transition-colors">Contacto</a></li>
        </ul>
      </div>
      
      <div>
